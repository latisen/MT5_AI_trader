# MetaTrader 5 terminal credentials (demo account recommended)
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=YourBroker-Demo
MT5_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Runtime
BOT_SYMBOL=EURUSD
BOT_TIMEFRAME=M15
BOT_MODE=SIGNAL_ONLY
ANALYZE_ON_NEW_CANDLE_ONLY=true
MARKET_HOURS_ENABLED=true
MARKET_OPEN_DAY=SUNDAY
MARKET_OPEN_TIME_UTC=22:05
MARKET_CLOSE_DAY=FRIDAY
MARKET_CLOSE_TIME_UTC=21:55
TRADING_ENABLED=false
LOOP_SECONDS=30
MAX_SPREAD_POINTS=30
LOG_DIR=logs
AI_TIMEOUT_SECONDS=20
